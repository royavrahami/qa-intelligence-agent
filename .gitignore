# ── Secrets & environment – NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
*.env
secrets.json
credentials.json

# ── Database (local runtime state) ────────────────────────────────────────────
data/
*.db
*.sqlite
*.db-shm
*.db-wal

# ── Generated reports (runtime output) ────────────────────────────────────────
reports/
# Keep templates that are part of the source
!src/reports/
!src/reports/**

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/

# ── Test & coverage artifacts ─────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
